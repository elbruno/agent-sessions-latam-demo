@page "/popocatepetl"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using BalizasV16.Models
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>🌋 Monitor Popocatépetl — Tiempo Real</PageTitle>

<div class="volcano-layout">
    <!-- Main content -->
    <div class="volcano-main">
        <div class="volcano-header">
            <div>
                <h1>🌋 Monitor del Popocatépetl</h1>
                <span class="volcano-sub">5,426 m — "Montaña que humea" — Datos en tiempo real</span>
            </div>
            @if (_data != null)
            {
                <div class="semaforo" style="background:@_data.AlertColor">
                    <span class="semaforo-label">Semáforo Volcánico</span>
                    <span class="semaforo-level">@_data.AlertLevel</span>
                </div>
            }
        </div>

        <!-- Metrics Cards -->
        @if (_data != null)
        {
            <div class="volcano-metrics">
                <div class="metric-card">
                    <span class="metric-icon">💨</span>
                    <span class="metric-value">@_data.ExhalationsToday</span>
                    <span class="metric-label">Exhalaciones (hoy)</span>
                </div>
                <div class="metric-card">
                    <span class="metric-icon">📊</span>
                    <span class="metric-value">@_data.TremorMinutes min</span>
                    <span class="metric-label">Tremor</span>
                </div>
                <div class="metric-card">
                    <span class="metric-icon">💥</span>
                    <span class="metric-value">@_data.ExplosionsToday</span>
                    <span class="metric-label">Explosiones</span>
                </div>
                <div class="metric-card">
                    <span class="metric-icon">🔴</span>
                    <span class="metric-value">@_data.VolcanoTectonicEvents</span>
                    <span class="metric-label">Eventos V-T</span>
                </div>
                <div class="metric-card">
                    <span class="metric-icon">📡</span>
                    <span class="metric-value">@_data.NearbyEarthquakes.Count</span>
                    <span class="metric-label">Sismos cercanos</span>
                </div>
                <div class="metric-card">
                    <span class="metric-icon">🕐</span>
                    <span class="metric-value">@_data.LastUpdated.ToString("HH:mm")</span>
                    <span class="metric-label">Última actualización</span>
                </div>
            </div>
        }

        <!-- Map + Camera side by side -->
        <div class="volcano-visuals">
            <div class="volcano-map-container">
                <h3>🗺️ Mapa Sísmico (radio 50 km)</h3>
                <div id="volcanoMap" style="height:400px;border-radius:8px;"></div>
            </div>
            <div class="volcano-cam-container">
                <h3>📹 Cámara en Vivo — Tlamacas</h3>
                <div class="volcano-cam">
                    <iframe width="100%" height="400"
                        src="https://www.youtube.com/embed/dq5LX5lq-1Y?autoplay=1&mute=1"
                        frameborder="0" allow="autoplay; encrypted-media" allowfullscreen
                        style="border-radius:8px;">
                    </iframe>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel: Recent Earthquakes -->
    <div class="volcano-panel">
        <h3>📋 Sismos Recientes</h3>
        <p class="small text-muted">Radio 50 km del cráter</p>

        @if (_data != null)
        {
            @foreach (var quake in _data.NearbyEarthquakes.Take(30))
            {
                <div class="volcano-quake-item" style="border-left:3px solid @quake.SeverityColor">
                    <span class="vq-mag" style="color:@quake.SeverityColor">@quake.Magnitude.ToString("F1")</span>
                    <div class="vq-info">
                        <span class="vq-place">@quake.Place</span>
                        <span class="vq-time">@quake.Time.ToString("dd/MM HH:mm") UTC • @quake.Depth.ToString("F0") km prof.</span>
                    </div>
                </div>
            }
        }

        <div class="volcano-links">
            <h4>🔗 Recursos Oficiales</h4>
            <a href="https://www.cenapred.gob.mx/es/reportesVolcanesMX/" target="_blank">📄 Reportes CENAPRED</a>
            <a href="https://volcano.si.edu/volcano.cfm?vn=341090" target="_blank">🌍 Smithsonian GVP</a>
            <a href="https://webcamsdemexico.com/webcam/popocatepetl/" target="_blank">📹 Webcams de México</a>
            <a href="https://www.gob.mx/cenapred/articulos/semaforo-de-alerta-volcanica-220744" target="_blank">🚦 Semáforo Volcánico</a>
        </div>
    </div>
</div>

@code {
    private VolcanoData? _data;
    private HubConnection? _hubConnection;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("volcanoMap.init");

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/volcanohub"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<VolcanoData>("VolcanoUpdated", async (data) =>
            {
                _data = data;
                await JS.InvokeVoidAsync("volcanoMap.updateQuakes", data.NearbyEarthquakes);
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("RequestVolcanoData");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
        try { await JS.InvokeVoidAsync("volcanoMap.dispose"); } catch { }
    }
}
